# Copy to .env and adjust for your environment.
# cp .env.example .env

# Solana RPC endpoints (use a dedicated provider for production; public endpoints are rate-limited)
SOL_HTTPS=https://api.mainnet-beta.solana.com
SOL_WSS=wss://api.mainnet-beta.solana.com

# Log substring to match in transaction logs (Raydium AMM v4 pool init)
LOG_INSTRUCTION=initialize2

# Raydium AMM v4 program id (mainnet default)
RAYDIUM_LPV4=675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8
